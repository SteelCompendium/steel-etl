{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "culture.schema.json-2.0.0",
  "title": "Draw Steel Culture",
  "description": "A culture benefit that shapes a hero's upbringing, environment, or organization.",
  "type": "object",
  "required": ["name", "type"],
  "unevaluatedProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the culture benefit (e.g., \"Urban\", \"Bureaucratic\", \"Academic\")."
    },
    "type": {
      "const": "culture",
      "description": "Must always be 'culture'."
    },
    "culture_benefit_type": {
      "type": "string",
      "description": "The dimension of culture this represents (e.g., \"Environment\", \"Organization\", \"Upbringing\")."
    },
    "environment": {
      "type": "string",
      "description": "The environment of the culture (e.g., \"Urban\", \"Wilderness\")."
    },
    "organization": {
      "type": "string",
      "description": "The organizational structure of the culture."
    },
    "upbringing": {
      "type": "string",
      "description": "The upbringing style of the culture."
    },
    "skill_options": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Available skill choices (e.g., [\"interpersonal\", \"intrigue\"])."
    },
    "quick_build_skill": {
      "type": "string",
      "description": "Default skill for Quick Build (e.g., \"Alertness\")."
    },
    "language": {
      "type": "string",
      "description": "Language granted by the culture."
    },
    "content": {
      "type": "string",
      "description": "Raw markdown body of the culture description."
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata (SCC, source, etc.).",
      "additionalProperties": true
    }
  }
}
