{
    "$schema": "https://json-schema.org/draft/2019-09/schema",
    "$id": "statblock.schema.json-3.0.0",
    "title": "Draw Steel Statblock",
    "description": "A creature statblock for Draw Steel.",
    "type": "object",
    "required": [
        "name",
        "type",
        "level",
        "role",
        "organization",
        "keywords",
        "ev",
        "stamina",
        "speed",
        "size",
        "stability",
        "free_strike",
        "might",
        "agility",
        "reason",
        "intuition",
        "presence"
    ],
    "unevaluatedProperties": false,
    "properties": {
        "name": {
            "type": "string",
            "description": "The name of the creature."
        },
        "type": {
            "type": "string",
            "description": "Must always be 'statblock'"
        },
        "level": {
            "type": "integer",
            "description": "The creature's level.",
            "default": 0
        },
        "role": {
            "type": "string",
            "description": "The creature's combat role (e.g., Ambusher, Artillery, Brute, Controller, Defender, Harrier, Skirmisher).",
            "default": ""
        },
        "organization": {
            "type": "string",
            "description": "The creature's organizational type (e.g., Minion, Horde, Platoon, Elite, Solo, Leader).",
            "default": ""
        },
        "keywords": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Keywords for the creature (e.g., Goblin, Humanoid, Undead, Elemental).",
            "default": []
        },
        "ev": {
            "type": "string",
            "description": "Encounter Value (EV) of the creature.",
            "default": ""
        },
        "stamina": {
            "type": "string",
            "description": "The creature's max stamina.",
            "default": ""
        },
        "immunities": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "List of immunities (e.g., Magic 2, Psionic 2).",
            "default": []
        },
        "weaknesses": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "List of weaknesses (e.g., acid 3, holy 1).",
            "default": []
        },
        "speed": {
            "type": "integer",
            "description": "Movement speed of the creature (e.g., 5).",
            "default": 0
        },
        "movement": {
            "type": "string",
            "description": "Movement types of the creature (e.g., 'climb, fly, swim').",
            "default": ""
        },
        "size": {
            "type": "string",
            "description": "Size category (e.g., 1M for medium).",
            "default": ""
        },
        "stability": {
            "type": "integer",
            "description": "Stability value of the creature.",
            "default": 0
        },
        "free_strike": {
            "type": "integer",
            "description": "The free strike value.",
            "default": 0
        },
        "might": {
            "type": "integer",
            "description": "Might modifier.",
            "default": 0
        },
        "agility": {
            "type": "integer",
            "description": "Agility modifier.",
            "default": 0
        },
        "reason": {
            "type": "integer",
            "description": "Reason modifier.",
            "default": 0
        },
        "intuition": {
            "type": "integer",
            "description": "Intuition modifier.",
            "default": 0
        },
        "presence": {
            "type": "integer",
            "description": "Presence modifier.",
            "default": 0
        },
        "with_captain": {
            "type": "string",
            "description": "Effect when a captain is present."
        },
        "statblock_kind": {
            "type": "string",
            "enum": ["fixture"],
            "description": "Marks non-creature statblock variants. Fixtures (Summoner book) use a loose 2-column stat header and render via the featureblock path."
        },
        "terrain_type": {
            "type": "string",
            "description": "Fixture classifier from the italic role line (e.g. 'Hazard' from 'Hazard Support')."
        },
        "features": {
            "type": "array",
            "items": {
                "$ref": "feature.schema.json-3.0.0#"
            },
            "description": "List of features (see Feature schema).",
            "default": []
        },
        "metadata": {
            "type": "object",
            "description": "Additional metadata (SCC, source, etc.).",
            "additionalProperties": true
        }
    }
}