{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "class.schema.json-1.0.0",
  "title": "Draw Steel Class",
  "description": "A hero class definition for Draw Steel.",
  "type": "object",
  "required": ["name", "type"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the class (e.g., \"Fury\", \"Tactician\")."
    },
    "type": {
      "const": "class",
      "description": "Must always be 'class'."
    },
    "heroic_resource": {
      "type": "string",
      "description": "The heroic resource used by the class (e.g., \"Rage\", \"Focus\")."
    },
    "content": {
      "type": "string",
      "description": "Raw markdown body of the class description."
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata (SCC, source, etc.).",
      "additionalProperties": true
    }
  }
}
