{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "ancestry.schema.json-1.0.0",
  "title": "Draw Steel Ancestry",
  "description": "A hero ancestry for Draw Steel.",
  "type": "object",
  "required": ["name", "type"],
  "unevaluatedProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the ancestry (e.g., \"Human\", \"Hakaan\", \"Memonek\")."
    },
    "type": {
      "const": "ancestry",
      "description": "Must always be 'ancestry'."
    },
    "signature_trait": {
      "type": "string",
      "description": "The signature trait of the ancestry."
    },
    "content": {
      "type": "string",
      "description": "Raw markdown body of the ancestry description."
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata (SCC, source, etc.).",
      "additionalProperties": true
    }
  }
}
